#include <bits/stdc++.h>
using namespace std;

int main() {
	// your code goes here
	int max1=0,max2=0;
	int a[]={20,10,40,80,45,60};
	int n=sizeof(a)/sizeof(a[0]);
	if(a[0]>a[1]){
	    max1=a[0];
	    max2=a[1];
	}
	else{
	    max1=a[1];
	    max2=a[0];
	}
	for(int i=2;i<n;i++){
	    if(a[i]>max1){
	        max2=max1;
	        max1=a[i];
	    }
	    else if(a[i]>max2){
	        max2=a[i];
	    }
	}
	cout<<max2<<endl;
	

}
